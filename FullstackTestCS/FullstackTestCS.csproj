    <UseWPF>true</UseWPF>
    <UserSecretsId>a6594589-bda1-4deb-8096-1383b7df4c36</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="scripts\001__CreateTableAunos.sql" />
